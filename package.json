{
  "name": "meetings-transcript",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev\" \"npm run dev:socket\"",
    "dev:socket": "tsup src/server/socket.ts --format cjs --target node18 --out-dir dist/server --splitting false --watch --onSuccess \\\"node socket-server.js\\\"",
    "build": "npm run build:socket && next build",
    "build:socket": "tsup src/server/socket.ts --format cjs --target node18 --out-dir dist/server --splitting false --clean",
    "start": "npm run build:socket && concurrently \"next start\" \"node socket-server.js\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "socket": "npm run build:socket && node socket-server.js"
  },
  "dependencies": {
    "@deepgram/sdk": "^3.1.5",
    "@langchain/core": "^0.2.0",
    "@langchain/openai": "^0.2.0",
    "@langchain/textsplitters": "^0.0.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@supabase/ssr": "^0.4.0",
    "@supabase/supabase-js": "^2.39.0",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.35.7",
    "@xenova/transformers": "^2.14.1",
    "audio-recorder-polyfill": "^0.4.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "concurrently": "^8.2.2",
    "ffmpeg-static": "^5.2.0",
    "inngest": "^3.46.0",
    "lucide-react": "^0.294.0",
    "next": "14.0.4",
    "next-themes": "^0.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "stripe": "^14.8.0",
    "tailwind-merge": "^2.2.0",
    "ytdl-core": "^4.11.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0-beta.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.10.4",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "eslint": "^8.55.0",
    "eslint-config-next": "14.0.4",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.32",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.0.0-beta.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
